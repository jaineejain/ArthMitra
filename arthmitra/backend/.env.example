GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Use 127.0.0.1 on Windows to avoid IPv6 (::1) auth quirks; include password for user postgres
DATABASE_URL=postgresql://postgres:your_password@127.0.0.1:5432/arthmitra
ENVIRONMENT=development
MFAPI_BASE=https://api.mfapi.in/mf

# Auth — use a long random secret in production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-in-production-min-32-chars-please
JWT_EXPIRE_MINUTES=10080

# Optional: comma-separated browser origins allowed to call the API (default includes Vite ports)
# CORS_ORIGINS=https://your-frontend.com,http://localhost:5173

